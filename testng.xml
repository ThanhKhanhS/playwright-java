<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" parallel="classes" thread-count="3">

    <test name="Form Test">
        <classes>
            <class name="tests.FormTest"/>
        </classes>
    </test>
    <test name="Frame Tests">
        <classes>
            <class name="tests.FrameTest"/>
        </classes>
    </test>

    <test name="Nested Frame Tests">
        <classes>
            <class name="tests.NestedFrameTest"/>
        </classes>
    </test>

    <test name="Drag And Drop Tests">
        <classes>
            <class name="tests.DragAndDropTest"/>
        </classes>
    </test>
</suite>